---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('projects');
const work = all
  .filter((p) => p.data.type === 'work')
  .sort((a, b) => a.data.order - b.data.order);
const personal = all
  .filter((p) => p.data.type === 'personal')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Projects — Aminu Abdusalam" description="Things I've built, at work and on the side.">
  <section class="container prose">
    <h1>Projects</h1>
    <p class="lead">
      A running list of things I've built — a few flagship ships at work, plus the personal
      and personal projects that got me here.
    </p>

    {work.length > 0 && (
      <div class="section">
        <h2>Selected work</h2>
        <p class="section-lede">Shipped at Microsoft.</p>
        <ul class="grid work-grid">
          {work.map((p) => (
            <li class="card card-large">
              <div class="card-head">
                <h3>{p.data.title}</h3>
                <span class="year">{p.data.year}</span>
              </div>
              {p.data.role && <span class="role">{p.data.role}</span>}
              <p>{p.data.description}</p>
              {p.data.stack.length > 0 && (
                <ul class="stack">
                  {p.data.stack.map((s) => <li>{s}</li>)}
                </ul>
              )}
              {p.data.launches.length > 0 && (
                <div class="launches">
                  <h4>Recent launches</h4>
                  <ul>
                    {p.data.launches.slice(0, 3).map((l) => (
                      <li>
                        <span class="launch-year">{l.year}</span>
                        {l.url ? (
                          <a href={l.url} target="_blank" rel="noopener">{l.title}</a>
                        ) : (
                          <span class="launch-title">{l.title}</span>
                        )}
                      </li>
                    ))}
                  </ul>
                  {p.data.launches.length > 3 && (
                    <details class="launches-more">
                      <summary>Show {p.data.launches.length - 3} more launches</summary>
                      <ul>
                        {p.data.launches.slice(3).map((l) => (
                          <li>
                            <span class="launch-year">{l.year}</span>
                            {l.url ? (
                              <a href={l.url} target="_blank" rel="noopener">{l.title}</a>
                            ) : (
                              <span class="launch-title">{l.title}</span>
                            )}
                          </li>
                        ))}
                      </ul>
                    </details>
                  )}
                </div>
              )}
              <div class="links">
                {p.data.link && <a href={p.data.link} target="_blank" rel="noopener">Read more →</a>}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}

    {personal.length > 0 && (
      <div class="section">
        <h2>Personal projects</h2>
        <p class="section-lede">Side projects and hackathons, mostly from before Microsoft... but have some in stealth mode and I stay cooking.</p>
        <ul class="grid personal-grid">
          {personal.map((p) => (
            <li class="card card-small">
              <div class="card-head">
                <h3>{p.data.title}</h3>
              </div>
              <p>{p.data.description}</p>
              {p.data.stack.length > 0 && (
                <ul class="stack">
                  {p.data.stack.map((s) => <li>{s}</li>)}
                </ul>
              )}
              <div class="links">
                {p.data.link && <a href={p.data.link} target="_blank" rel="noopener">Live →</a>}
                {p.data.repo && <a href={p.data.repo} target="_blank" rel="noopener">Code →</a>}
                {p.data.press.map((m) => (
                  <a href={m.url} target="_blank" rel="noopener">{m.label} →</a>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .prose {
    padding-block: var(--space-10) var(--space-8);
  }
  h1 {
    font-size: var(--fs-3xl);
    margin-bottom: var(--space-3);
  }
  .lead {
    color: var(--color-text-muted);
    margin-bottom: var(--space-10);
    max-width: 60ch;
  }
  .section {
    margin-bottom: var(--space-12);
  }
  .section h2 {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: var(--fs-xl);
    margin-bottom: var(--space-2);
  }
  .section h2::before {
    content: '## ';
    color: var(--color-text-dim);
  }
  .section-lede {
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    margin-bottom: var(--space-5);
  }
  .grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: var(--space-5);
  }
  .work-grid {
    grid-template-columns: 1fr;
  }
  .personal-grid {
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    transition: all var(--duration-base) var(--ease-out);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .card:hover {
    border-color: var(--color-accent-dim);
    transform: translateY(-3px);
    box-shadow: var(--shadow-glow);
  }
  .card-large {
    padding: var(--space-6);
    border-left: 3px solid var(--color-accent);
  }
  .card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
  }
  .card h3 {
    color: var(--color-text-strong);
  }
  .card-large h3 {
    font-size: var(--fs-xl);
  }
  .card-small h3 {
    font-size: var(--fs-lg);
  }
  .year {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
    white-space: nowrap;
  }
  .role {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .card p {
    color: var(--color-text-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    flex-grow: 1;
  }
  .card-large p {
    color: var(--color-text);
    font-size: var(--fs-base);
  }
  .stack {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .stack li {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 2px 8px;
    border-radius: var(--radius-full);
  }
  .launches {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
    margin-top: var(--space-2);
  }
  .launches h4 {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 var(--space-3) 0;
  }
  .launches ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .launches li {
    display: flex;
    gap: var(--space-3);
    align-items: baseline;
    font-size: var(--fs-sm);
    line-height: var(--lh-normal);
  }
  .launch-year {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
    min-width: 3.5ch;
    flex-shrink: 0;
  }
  .launch-title {
    color: var(--color-text-muted);
  }
  .launches-more {
    margin-top: var(--space-3);
  }
  .launches-more summary {
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-accent);
    padding: var(--space-1) 0;
    user-select: none;
    list-style: none;
    display: inline-block;
  }
  .launches-more summary::-webkit-details-marker {
    display: none;
  }
  .launches-more summary::before {
    content: '+ ';
    display: inline-block;
    min-width: 1.5ch;
  }
  .launches-more[open] summary::before {
    content: '- ';
  }
  .launches-more summary:hover {
    color: var(--color-accent-bright, var(--color-accent));
  }
  .launches-more ul {
    margin-top: var(--space-2);
  }
  .links {
    display: flex;
    gap: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    margin-top: var(--space-2);
  }
</style>
