---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found" description="This page doesn't exist.">
  <section class="container container-narrow four04">
    <div class="terminal">
      <div class="terminal-header">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
        <span class="terminal-title">~/wat</span>
      </div>
      <div class="terminal-body">
        <p><span class="prompt">$</span> cd {Astro.url.pathname}</p>
        <p class="err">bash: cd: {Astro.url.pathname}: No such file or directory</p>
        <p><span class="prompt">$</span> ls</p>
        <p class="output">
          <a href="/">home</a>  <a href="/about">about</a>  <a href="/projects">projects</a>  <a href="/writing">writing</a>
        </p>
        <p><span class="prompt">$</span> <span class="blink">▊</span></p>
      </div>
    </div>
    <p class="hint">
      Maybe try the <a href="/">home page</a>, or <a href="mailto:aminuabdusalam2019@gmail.com">let me know</a> what you were looking for.
    </p>
  </section>
</BaseLayout>

<style>
  .four04 {
    padding-block: var(--space-12);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-8);
  }
  .terminal {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    width: 100%;
    max-width: 560px;
    box-shadow: var(--shadow-md);
  }
  .terminal-header {
    background: var(--color-bg-hover);
    padding: var(--space-2) var(--space-4);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }
  .dot { width: 12px; height: 12px; border-radius: 50%; display: inline-block; }
  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }
  .terminal-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--color-text-dim);
  }
  .terminal-body {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    line-height: var(--lh-snug);
  }
  .terminal-body p { margin-block: 4px; }
  .prompt { color: var(--color-accent); margin-right: 8px; }
  .output { color: var(--color-text-muted); padding-left: 20px; display: flex; gap: var(--space-4); flex-wrap: wrap; }
  .err { color: #ff8b8b; padding-left: 20px; }
  .blink { animation: blink 1s steps(2) infinite; color: var(--color-accent); }
  @keyframes blink { 50% { opacity: 0; } }
  .hint {
    color: var(--color-text-muted);
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
  }
</style>
